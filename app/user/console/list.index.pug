extends /resources/angle/pug/list-page
include /resources/angle/pug/mixins/list

block list
  list.panel.panel-default(list="vm.list")
    list-header(text="console.session.list.TITLE")
      a.btn.btn-default(ng-click="vm.list.refresh.now()")
        i.fa.fa-refresh
    console-session-table.border-top-table.scrollable-block(show-creator="true" can-write="vm.canWrite")
    list-footer

block bottom-right
  logs(
    heading="Console Server Logs"
    filter="vm.logs.filter"
    listen-to="vm.list"
  )
